# ─── Rust 编译产物 ───────────────────────────
/target/
**/*.rs.bk

# ─── Cargo 锁文件（库保留，应用忽略可选）───
# 如果是应用（binary crate）建议提交 Cargo.lock
# 如果是库（library crate）建议忽略
# Cargo.lock

# ─── IDE / 编辑器 ────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── 运行时数据 ──────────────────────────────
# 日志文件
*.log
logs/

# ─── 配置文件（含敏感信息的不提交）─────────
# 实际运行配置（含密码/证书路径等），只提交示例
config/sweety.toml

# ─── TLS 证书 ────────────────────────────────
*.pem
*.crt
*.cer
*.key
*.p12
*.pfx

# ─── ACME 缓存（含账号私钥和证书）──────────
.acme/
acme_cache/

# ─── 环境变量文件 ────────────────────────────
.env
.env.*
!.env.example

# ─── 临时文件 ────────────────────────────────
*.tmp
*.bak
*.orig
